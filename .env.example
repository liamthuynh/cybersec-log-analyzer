# =============================================================================
# CyberScope — Environment Variables
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the required values (marked with REQUIRED)
# 3. NEVER commit .env to version control
# =============================================================================


# -----------------------------------------------------------------------------
# [REQUIRED] Flask secret key — used to sign JWT tokens
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=your-strong-random-secret-here

# -----------------------------------------------------------------------------
# [OPTIONAL] Anthropic API key — enables AI-powered log analysis
# Without this, the app falls back to rule-based analysis only.
# Get a key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# [OPTIONAL] AI model override (defaults to claude-sonnet-4-6)
# -----------------------------------------------------------------------------
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=2000
# AI_MAX_SAMPLE_ENTRIES=50

# -----------------------------------------------------------------------------
# Flask server
# -----------------------------------------------------------------------------
FLASK_ENV=development     # development | production
FLASK_DEBUG=1             # 1 = on, 0 = off  (always 0 in production)
HOST=0.0.0.0
PORT=5000

# -----------------------------------------------------------------------------
# PostgreSQL
# For local non-Docker backend runs, set DATABASE_URL to a localhost Postgres DSN.
# Docker Compose builds the backend DSN from the POSTGRES_* values automatically.
# -----------------------------------------------------------------------------
POSTGRES_DB=cyberscope
POSTGRES_USER=cyberscope
POSTGRES_PASSWORD=cyberscope
# DATABASE_URL=postgresql://cyberscope:cyberscope@localhost:5432/cyberscope

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# In production set this to your actual frontend URL, e.g. https://app.example.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Docker Compose port overrides (optional)
# -----------------------------------------------------------------------------
BACKEND_PORT=5000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Next.js rewrite target used inside the frontend container
# -----------------------------------------------------------------------------
BACKEND_INTERNAL_URL=http://backend:5000
